# Copia in .env.local e riempi i valori. Solo lato server (non esposto al browser).
#
# OPENAI_API_KEY (richiesta) — chiave API usata dal route handler
#   /api/suggestions per generare i suggerimenti dell'orto.
OPENAI_API_KEY=

# Modello da usare. Default: gpt-4o-mini.
# Esempi: gpt-4o-mini, gpt-4.1-mini, gpt-4o
# OPENAI_MODEL=gpt-4o-mini

# Endpoint base. Default: https://api.openai.com/v1
# Cambialo se usi OpenRouter, Azure OpenAI, o un proxy compatibile (es. Ollama).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Base URL dell'app (serve per metadataBase, sitemap.xml, robots.txt).
# In produzione: https://tuo-dominio.tld
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Donazioni (consigliato: Stripe Payment Links).
# Puoi impostare un solo link o 3 livelli.
# NEXT_PUBLIC_DONATE_LINK=
# NEXT_PUBLIC_DONATE_LINK_SMALL=
# NEXT_PUBLIC_DONATE_LINK_MED=
# NEXT_PUBLIC_DONATE_LINK_LARGE=
